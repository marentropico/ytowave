{
  "name": "ytowave",
  "version": "1.0.0",
  "description": "Desktop music download manager – downloads in high-quality WAV via yt-dlp + FFmpeg",
  "main": "electron/main.js",
  "author": "YtoWave",
  "license": "MIT",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/download-binaries.js",
    "dev:renderer": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently -n renderer,electron -c cyan,yellow \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "extract-zip": "^2.0.1",
    "isomorphic-unfetch": "^4.0.2",
    "spotify-url-info": "^3.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.2.0",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.3",
    "wait-on": "^8.0.0",
    "zustand": "^4.5.4"
  }
}
